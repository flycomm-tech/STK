# ── ClickHouse Connection ─────────────────────────────────────────
# Copy this file to .env and fill in your credentials.

CH_HOST=your-instance.clickhouse.cloud
CH_PORT=8443
CH_DB=default
CH_USER=default
CH_PASSWORD=your_password_here
CH_SSL=true

# ── Security ─────────────────────────────────────────────────────
# Encryption key for secrets at rest (CH passwords in DB).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=CHANGE-ME-generate-a-random-key

# JWT secret for auth tokens. Must be random in production.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=CHANGE-ME-generate-a-random-key

# Set to "true" ONLY for local development — enables /dev-login (no-password auth)
DEV_MODE=false
